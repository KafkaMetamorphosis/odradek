{
  "server": {"port": 8082},
  "orchestrator-config": {
    "rate-interval-ms": 100,
    "scrape-interval-ms": 30000
  },
  "kafka_clusters": {
    "local-1": {"bootstrap-url": "localhost:9092"}
  },
  "observers": [
    {
      "name": "topic-config",
      "clusters": ["local-1"],
      "observer-type": "topic-info",
      "topics-filter": ".*",
      "observe-configs": [
        "min.insync.replicas",
        "retention.ms",
        "retention.bytes",
        "cleanup.policy",
        "max.message.bytes",
        "compression.type"
      ]
    },
    {
      "name": "1kb-messages-small-topic-producer",
      "clusters": ["local-1"],
      "topic": "1KB-TOPIC",
      "observer-type": "producer",
      "custom-labels": {
        "slo-production-latency-ms": 80,
        "slo-latency-meta-ms": 99.5,
        "slo-latency-window-minutes": 1
      },
      "volume-config": {
        "parallelism": 1,
        "messages-per-interval": 10,
        "message-size-kb": 10
      },
      "producer-config": {
        "acks": "all",
        "linger.ms": "0",
        "retries": "3",
        "delivery.timeout.ms": "5000",
        "request.timeout.ms": "1500"
      }
    },
    {
      "name": "1kb-messages-small-topic-consumer",
      "clusters": ["local-1"],
      "topic": "1KB-TOPIC",
      "observer-type": "consumer",
      "custom-labels": {
        "slo-fetch-latency-ms": 500,
        "slo-e2e-message-age-ms": 1000,
        "slo-full-e2e-ms": 1080,
        "slo-latency-meta-ms": 99.5,
        "slo-latency-window-minutes": 1
      },
      "consumer-config": {
        "max.poll.interval.ms": "30000",
        "heartbeat.interval.ms": "3000",
        "session.timeout.ms": "30000"
      }
    },
    {
      "name": "10kb-messages-small-topic-producer",
      "clusters": ["local-1"],
      "topic": "10KB-TOPIC",
      "observer-type": "producer",
      "custom-labels": {
        "slo-production-latency-ms": 80,
        "slo-latency-meta-ms": 99.5,
        "slo-latency-window-minutes": 1
      },
      "volume-config": {
        "parallelism": 1,
        "messages-per-interval": 10,
        "message-size-kb": 10
      },
      "producer-config": {
        "acks": "all",
        "linger.ms": "0",
        "retries": "3",
        "delivery.timeout.ms": "5000",
        "request.timeout.ms": "1500"
      }
    },
    {
      "name": "10kb-messages-small-topic-consumer",
      "clusters": ["local-1"],
      "topic": "10KB-TOPIC",
      "observer-type": "consumer",
      "custom-labels": {
        "slo-fetch-latency-ms": 500,
        "slo-e2e-message-age-ms": 1000,
        "slo-full-e2e-ms": 1080,
        "slo-latency-meta-ms": 99.5,
        "slo-latency-window-minutes": 1
      },
      "consumer-config": {
        "max.poll.interval.ms": "30000",
        "heartbeat.interval.ms": "3000",
        "session.timeout.ms": "30000"
      }
    },
    {
      "name": "100kb-messages-small-topic-producer",
      "clusters": ["local-1"],
      "topic": "100KB-TOPIC",
      "observer-type": "producer",
      "custom-labels": {
        "slo-production-latency-ms": 150,
        "slo-latency-meta-ms": 99.5,
        "slo-latency-window-minutes": 1
      },
      "volume-config": {
        "parallelism": 1,
        "messages-per-interval": 10,
        "message-size-kb": 10
      },
      "producer-config": {
        "acks": "all",
        "linger.ms": "0",
        "retries": "3",
        "delivery.timeout.ms": "5000",
        "request.timeout.ms": "1500"
      }
    },
    {
      "name": "100kb-messages-small-topic-consumer",
      "clusters": ["local-1"],
      "topic": "100KB-TOPIC",
      "observer-type": "consumer",
      "custom-labels": {
        "slo-fetch-latency-ms": 500,
        "slo-e2e-message-age-ms": 1000,
        "slo-full-e2e-ms": 1150,
        "slo-latency-meta-ms": 99.5,
        "slo-latency-window-minutes": 1
      },
      "consumer-config": {
        "max.poll.interval.ms": "30000",
        "heartbeat.interval.ms": "3000",
        "session.timeout.ms": "30000"
      }
    },
    {
      "name": "1mb-messages-small-topic-producer",
      "clusters": ["local-1"],
      "topic": "1MB-MESSAGES-SMALL-TOPIC",
      "observer-type": "producer",
      "volume-config": {
        "parallelism": 1,
        "messages-per-interval": 3,
        "message-size-kb": 1024
      },
      "custom-labels": {
        "slo-production-latency-ms": 250,
        "slo-latency-meta-ms": 99,
        "slo-latency-window-minutes": 5
      },
      "producer-config": {
        "acks": "all",
        "linger.ms": "0",
        "retries": "3",
        "delivery.timeout.ms": "30000",
        "request.timeout.ms": "10000",
        "max.request.size": "2097152"
      }
    },
    {
      "name": "1mb-messages-small-topic-consumer",
      "clusters": ["local-1"],
      "topic": "1MB-MESSAGES-SMALL-TOPIC",
      "observer-type": "consumer",
      "custom-labels": {
        "slo-fetch-latency-ms": 500,
        "slo-e2e-message-age-ms": 1000,
        "slo-full-e2e-ms": 1250,
        "slo-latency-meta-ms": 99,
        "slo-latency-window-minutes": 5
      },
      "consumer-config": {
        "max.poll.interval.ms": "30000",
        "heartbeat.interval.ms": "3000",
        "session.timeout.ms": "30000",
        "fetch.max.bytes": "10485760",
        "max.partition.fetch.bytes": "10485760"
      }
    },
    {
      "name": "5mb-messages-small-topic-producer",
      "clusters": ["local-1"],
      "topic": "5MB-MESSAGES-SMALL-TOPIC",
      "observer-type": "producer",
      "volume-config": {
        "parallelism": 1,
        "messages-per-interval": 2,
        "message-size-kb": 5120
      },
      "custom-labels": {
        "slo-production-latency-ms": 700,
        "slo-latency-meta-ms": 99,
        "slo-latency-window-minutes": 5
      },
      "producer-config": {
        "acks": "all",
        "linger.ms": "0",
        "retries": "3",
        "delivery.timeout.ms": "30000",
        "request.timeout.ms": "10000",
        "max.request.size": "10485760"
      }
    },
    {
      "name": "5mb-messages-small-topic-consumer",
      "clusters": ["local-1"],
      "topic": "5MB-MESSAGES-SMALL-TOPIC",
      "observer-type": "consumer",
      "custom-labels": {
        "slo-fetch-latency-ms": 1200,
        "slo-e2e-message-age-ms": 2400,
        "slo-full-e2e-ms": 3100,
        "slo-latency-meta-ms": 99,
        "slo-latency-window-minutes": 5
      },
      "consumer-config": {
        "max.poll.interval.ms": "30000",
        "heartbeat.interval.ms": "3000",
        "session.timeout.ms": "30000",
        "fetch.max.bytes": "10485760",
        "max.partition.fetch.bytes": "10485760"
      }
    },
    {
      "name": "9mb-messages-small-topic-producer",
      "clusters": ["local-1"],
      "topic": "9MB-MESSAGES-SMALL-TOPIC",
      "observer-type": "producer",
      "volume-config": {
        "parallelism": 1,
        "messages-per-interval": 1,
        "message-size-kb": 9216
      },
      "custom-labels": {
        "slo-production-latency-ms": 800,
        "slo-latency-meta-ms": 95,
        "slo-latency-window-minutes": 5
      },
      "producer-config": {
        "acks": "all",
        "linger.ms": "0",
        "retries": "3",
        "delivery.timeout.ms": "30000",
        "request.timeout.ms": "10000",
        "max.request.size": "10485760"
      }
    },
    {
      "name": "9mb-messages-small-topic-consumer",
      "clusters": ["local-1"],
      "topic": "9MB-MESSAGES-SMALL-TOPIC",
      "custom-labels": {
        "slo-fetch-latency-ms": 1500,
        "slo-e2e-message-age-ms": 3000,
        "slo-full-e2e-ms": 3800,
        "slo-latency-meta-ms": 95,
        "slo-latency-window-minutes": 5
      },
      "observer-type": "consumer",
      "consumer-config": {
        "max.poll.interval.ms": "30000",
        "heartbeat.interval.ms": "3000",
        "session.timeout.ms": "30000",
        "fetch.max.bytes": "10485760",
        "max.partition.fetch.bytes": "10485760"
      }
    }
  ]
}
