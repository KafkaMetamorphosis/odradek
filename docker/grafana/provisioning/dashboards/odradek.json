    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "type": "stat",
      "title": "SLO 1: Production Latency (p99 < 10ms)",
      "description": "Target: 99.98% of 1m windows have p99 production latency < 10ms",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99.5 },
              { "color": "green", "value": 99.98 }
            ]
          },
          "min": 95,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "(\n  1 - clamp_min(\n    histogram_quantile(0.99, sum(rate(kafka_odradek_messages_production_latency_ms_bucket[1m])) by (le))\n    / 10, 0\n  ) + clamp_max(\n    histogram_quantile(0.99, sum(rate(kafka_odradek_messages_production_latency_ms_bucket[1m])) by (le))\n    / 10, 1\n  )\n) * 100\nor\n(\n  (histogram_quantile(0.99, sum(rate(kafka_odradek_messages_production_latency_ms_bucket[1m])) by (le)) <= bool 10) * 100\n)",
