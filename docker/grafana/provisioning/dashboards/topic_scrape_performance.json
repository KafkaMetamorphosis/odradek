{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["kafka", "odradek", "scrape", "performance"],
  "templating": {
    "list": [
      {
        "name": "cluster_name",
        "label": "Cluster",
        "description": "Select the Kafka cluster to inspect scrape performance for",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": {
          "query": "label_values(kafka_odradek_topic_scrape_duration_seconds_count, cluster_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "hide": 0,
        "current": {}
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Odradek - Topic Scrape Performance",
  "uid": "odradek-scrape-perf",
  "version": 1,
  "panels": [
    {
      "type": "row",
      "title": "Scrape Cycle",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "type": "stat",
      "title": "Last Scrape Duration (p99)",
      "description": "p99 scrape cycle duration over the last 5 minutes. Green <1s, yellow <5s, red ≥5s.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(kafka_odradek_topic_scrape_duration_seconds_bucket{cluster_name=~\"$cluster_name\"}[5m]))",
          "legendFormat": "p99 Scrape Duration",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "type": "timeseries",
      "title": "Scrape Cycle Duration Over Time (p50 / p95 / p99)",
      "description": "Distribution of full scrape cycle durations. Use this to detect slowdowns or spikes in scrape time.",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 1 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "duration (s)",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(kafka_odradek_topic_scrape_duration_seconds_bucket{cluster_name=~\"$cluster_name\"}[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(kafka_odradek_topic_scrape_duration_seconds_bucket{cluster_name=~\"$cluster_name\"}[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(kafka_odradek_topic_scrape_duration_seconds_bucket{cluster_name=~\"$cluster_name\"}[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "type": "stat",
      "title": "Total Scrape Error Count",
      "description": "Cumulative number of scrape errors for this cluster. Any value ≥1 should be investigated.",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "sum(kafka_odradek_topic_scrape_errors_total{cluster_name=~\"$cluster_name\"})",
          "legendFormat": "Total Scrape Errors",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "type": "row",
      "title": "Step Breakdown",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "collapsed": false,
      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "type": "timeseries",
      "title": "Step Duration Comparison (p99)",
      "description": "p99 duration for each individual scrape step. Helps pinpoint which step is the bottleneck.",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 10 },
      "id": 10,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "duration (s)",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(kafka_odradek_topic_list_duration_seconds_bucket{cluster_name=~\"$cluster_name\"}[5m]))",
          "legendFormat": "List Topics",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, rate(kafka_odradek_topic_describe_duration_seconds_bucket{cluster_name=~\"$cluster_name\"}[5m]))",
          "legendFormat": "Describe Topics",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(kafka_odradek_topic_config_describe_duration_seconds_bucket{cluster_name=~\"$cluster_name\"}[5m]))",
          "legendFormat": "Describe Configs",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "type": "timeseries",
      "title": "Scrape Error Rate by Step",
      "description": "Rate of scrape errors broken down by the step where the error occurred.",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 10 },
      "id": 11,
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "errors/sec",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "rate(kafka_odradek_topic_scrape_errors_total{cluster_name=~\"$cluster_name\"}[5m])",
          "legendFormat": "{{step}}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "row",
      "title": "Topic Count",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "collapsed": false,
      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "type": "stat",
      "title": "Distinct Topics Currently Tracked",
      "description": "Number of unique topics with active partition metrics for this cluster.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 19 },
      "id": 20,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "count(kafka_odradek_topic_config{cluster_name=~\"$cluster_name\"})",
          "legendFormat": "Topics Tracked",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "type": "timeseries",
      "title": "Topic Count Over Time",
      "description": "Number of distinct topics tracked per scrape cycle. Drops or spikes may indicate cluster topology changes or scrape failures.",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 19 },
      "id": 21,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "topic count",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "count(kafka_odradek_topic_config{cluster_name=~\"$cluster_name\"})",
          "legendFormat": "Topics Tracked",
          "refId": "A"
        }
      ]
    }
  ]
}
